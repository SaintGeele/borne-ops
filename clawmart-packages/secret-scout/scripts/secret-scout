#!/bin/bash
# secret-scout CLI - Master command for SecretScout

SCRIPT_DIR="$HOME/.openclaw/workspace/clawmart-packages/secret-scout/scripts"
LOG_FILE="$HOME/.openclaw/logs/secrets-manager.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [CLI] $1" | tee -a "$LOG_FILE"
}

Usage() {
    echo "SecretScout CLI 🛰️"
    echo ""
    echo "Usage: secret-scout <command>"
    echo ""
    echo "Commands:"
    echo "  scan        Scan for hardcoded secrets"
    echo "  analyze     Entropy, age, duplicate analysis"
    echo "  audit       Full security audit"
    echo "  status      Show secret health status"
    echo "  backup      Create backup of configs"
    echo "  rotate      Rotate secrets"
    echo "  verify      Verify VAR references match .env"
    echo "  scope       List per-agent secret scopes"
    echo "  broker      MCP-compatible secret broker"
    echo "  digest      Generate weekly Telegram digest"
    echo ""
    echo "Examples:"
    echo "  secret-scout scan"
    echo "  secret-scout analyze"
    echo "  secret-scout scope --list"
    echo "  secret-scout broker list ivy"
    exit 1
}

COMMAND="${1:-}"
[ -z "$COMMAND" ] && Usage

shift || true

case "$COMMAND" in
    scan)
        bash "$SCRIPT_DIR/secret-scout-scan.sh" "$@"
        ;;
    analyze)
        bash "$SCRIPT_DIR/secret-scout-analyze.sh" "$@"
        ;;
    audit)
        echo "=== Full Security Audit ==="
        bash "$SCRIPT_DIR/secret-scout-scan.sh"
        echo ""
        bash "$SCRIPT_DIR/secret-scout-analyze.sh"
        ;;
    status)
        bash "$HOME/.openclaw/bin/secrets-preflight --check" --dry-run 2>&1 | grep -E "✅|❌|⚠️" || true
        ;;
    backup)
        bash "$HOME/.openclaw/bin/secrets-preflight --backup" "$@"
        ;;
    rotate)
        bash "$SCRIPT_DIR/secret-scout-rotate.sh" "$@"
        ;;
    verify)
        bash "$HOME/.openclaw/bin/secrets-preflight --verify-refs"
        ;;
    scope)
        bash "$SCRIPT_DIR/secret-scout-scope.sh" "$@"
        ;;
    broker)
        bash "$SCRIPT_DIR/secret-scout-broker.sh" "$@"
        ;;
    digest)
        bash "$SCRIPT_DIR/secret-scout-digest.sh" "$@"
        ;;
    *)
        echo "Unknown command: $COMMAND"
        Usage
        ;;
esac

log "Command executed: $COMMAND"
