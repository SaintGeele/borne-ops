#!/bin/bash
# secrets-preflight - Pre-flight check for OpenClaw secrets operations
# Usage: 
#   ./secrets-preflight --check        # Verify environment is safe to proceed
#   ./secrets-preflight --backup        # Create backup before changes
#   ./secrets-preflight --verify-refs   # Verify ${VAR} matches .env
#   ./secrets-preflight --dry-run       # Test without making changes

set -o pipefail

# Configuration
BACKUP_DIR="/home/saint/.openclaw/config-backups"
LOG_FILE="/home/saint/.openclaw/logs/secrets-manager.log"
OPENCLAW_CONFIG="$HOME/.openclaw/openclaw.json"
ENV_FILE="$HOME/.openclaw/.env"
DRY_RUN=false

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Logging function
log() {
    local level="$1"
    local message="$2"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$timestamp] [$level] $message" | tee -a "$LOG_FILE"
}

# Ensure log directory exists
mkdir -p "$(dirname "$LOG_FILE")"
mkdir -p "$BACKUP_DIR"

# Parse arguments
ACTION="check"
while [[ $# -gt 0 ]]; do
    case $1 in
        --check)
            ACTION="check"
            shift
            ;;
        --backup)
            ACTION="backup"
            shift
            ;;
        --verify-refs)
            ACTION="verify_refs"
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            echo "🔍 DRY RUN MODE - No changes will be made"
            shift
            ;;
        *)
            echo "Usage: $0 [--check|--backup|--verify-refs|--dry-run]"
            exit 1
            ;;
    esac
done

echo "========================================="
echo "  OpenClaw Secrets Pre-Flight Check"
echo "========================================="
echo ""

# Function: Check current state
do_check() {
    log "INFO" "Running pre-flight checks..."
    
    local errors=0
    
    # 1. Check if openclaw.json exists
    if [ ! -f "$OPENCLAW_CONFIG" ]; then
        echo -e "${RED}❌ openclaw.json not found${NC}"
        log "ERROR" "openclaw.json not found at $OPENCLAW_CONFIG"
        ((errors++))
    else
        echo -e "${GREEN}✅ openclaw.json exists${NC}"
    fi
    
    # 2. Check if .env exists
    if [ ! -f "$ENV_FILE" ]; then
        echo -e "${RED}❌ .env not found${NC}"
        log "ERROR" ".env not found at $ENV_FILE"
        ((errors++))
    else
        echo -e "${GREEN}✅ .env exists${NC}"
        
        # Check .env permissions
        local perms=$(stat -c %a "$ENV_FILE" 2>/dev/null)
        if [ "$perms" != "600" ]; then
            echo -e "${YELLOW}⚠️  .env permissions: $perms (should be 600)${NC}"
            log "WARN" ".env permissions are $perms, should be 600"
        else
            echo -e "${GREEN}✅ .env permissions correct (600)${NC}"
        fi
        
        # Check .env is not empty
        if [ ! -s "$ENV_FILE" ]; then
            echo -e "${RED}❌ .env is empty${NC}"
            log "ERROR" ".env is empty"
            ((errors++))
        else
            local line_count=$(wc -l < "$ENV_FILE")
            echo -e "${GREEN}✅ .env has $line_count lines${NC}"
        fi
    fi
    
    # 3. Check gateway service status
    local gateway_status=$(systemctl is-active openclaw 2>/dev/null || echo "unknown")
    if [ "$gateway_status" = "active" ]; then
        echo -e "${GREEN}✅ Gateway is active${NC}"
    else
        echo -e "${RED}❌ Gateway status: $gateway_status${NC}"
        log "WARN" "Gateway status: $gateway_status"
    fi
    
    # 4. Check backup directory exists and is writable
    if [ -d "$BACKUP_DIR" ] && [ -w "$BACKUP_DIR" ]; then
        echo -e "${GREEN}✅ Backup directory accessible${NC}"
    else
        echo -e "${RED}❌ Backup directory not accessible${NC}"
        ((errors++))
    fi
    
    echo ""
    if [ $errors -eq 0 ]; then
        echo -e "${GREEN}✅ All pre-flight checks passed${NC}"
        log "INFO" "Pre-flight checks passed"
        return 0
    else
        echo -e "${RED}❌ $errors check(s) failed${NC}"
        log "ERROR" "$errors pre-flight checks failed"
        return 1
    fi
}

# Function: Create backup
do_backup() {
    log "INFO" "Creating timestamped backup..."
    
    local timestamp=$(date +%Y%m%d_%H%M%S)
    
    if [ "$DRY_RUN" = true ]; then
        echo "🔍 [DRY RUN] Would create backup: ${OPENCLAW_CONFIG} -> ${BACKUP_DIR}/openclaw.json.backup_${timestamp}"
        echo "🔍 [DRY RUN] Would create backup: ${ENV_FILE} -> ${BACKUP_DIR}/.env.backup_${timestamp}"
        log "INFO" "[DRY RUN] Backup would be created"
        return 0
    fi
    
    # Verify original files exist before proceeding
    if [ ! -f "$OPENCLAW_CONFIG" ]; then
        echo -e "${RED}❌ Cannot backup - openclaw.json missing${NC}"
        log "ERROR" "Backup failed - openclaw.json missing"
        return 1
    fi
    
    if [ ! -f "$ENV_FILE" ]; then
        echo -e "${RED}❌ Cannot backup - .env missing${NC}"
        log "ERROR" "Backup failed - .env missing"
        return 1
    fi
    
    # Create backups
    cp "$OPENCLAW_CONFIG" "${BACKUP_DIR}/openclaw.json.backup_${timestamp}"
    echo "✅ Backed up: openclaw.json -> openclaw.json.backup_${timestamp}"
    log "INFO" "Backed up openclaw.json to ${BACKUP_DIR}/openclaw.json.backup_${timestamp}"
    
    cp "$ENV_FILE" "${BACKUP_DIR}/.env.backup_${timestamp}"
    echo "✅ Backed up: .env -> .env.backup_${timestamp}"
    log "INFO" "Backed up .env to ${BACKUP_DIR}/.env.backup_${timestamp}"
    
    echo ""
    echo "✅ Backup complete! Timestamp: $timestamp"
    log "INFO" "Backup completed successfully"
    
    # Verify backup was created and is non-empty
    if [ ! -s "${BACKUP_DIR}/openclaw.json.backup_${timestamp}" ]; then
        echo -e "${RED}❌ Backup verification failed - openclaw.json backup is empty${NC}"
        log "ERROR" "Backup verification failed - empty file"
        return 1
    fi
    
    if [ ! -s "${BACKUP_DIR}/.env.backup_${timestamp}" ]; then
        echo -e "${RED}❌ Backup verification failed - .env backup is empty${NC}"
        log "ERROR" "Backup verification failed - empty file"
        return 1
    fi
    
    echo "✅ Backup verified - files are non-empty"
    return 0
}

# Function: Verify ${VAR} references in openclaw.json match .env entries
do_verify_refs() {
    log "INFO" "Verifying \${VAR} references in openclaw.json..."
    
    local errors=0
    local missing_vars=()
    
    # Extract all ${VAR} patterns from openclaw.json
    local refs=$(grep -oP '\$\{[A-Za-z_][A-Za-z0-9_]*\}' "$OPENCLAW_CONFIG" 2>/dev/null | sort -u)
    
    if [ -z "$refs" ]; then
        echo "No \${VAR} references found in openclaw.json"
        return 0
    fi
    
    echo "Found \${VAR} references:"
    echo "$refs" | while read -r ref; do
        local var_name=$(echo "$ref" | tr -d '${}')
        echo "  - $var_name"
    done
    
    # Check each reference against .env
    echo ""
    echo "Checking against .env..."
    
    for ref in $refs; do
        local var_name=$(echo "$ref" | tr -d '${}')
        
        # Check if variable exists in .env and is not empty
        if grep -q "^${var_name}=" "$ENV_FILE" 2>/dev/null; then
            local value=$(grep "^${var_name}=" "$ENV_FILE" | cut -d'=' -f2-)
            if [ -n "$value" ]; then
                echo -e "  ✅ $var_name: present and populated"
            else
                echo -e "  ❌ $var_name: present but EMPTY"
                missing_vars+=("$var_name")
                ((errors++))
            fi
        else
            echo -e "  ❌ $var_name: MISSING from .env"
            missing_vars+=("$var_name")
            ((errors++))
        fi
    done
    
    echo ""
    if [ $errors -gt 0 ]; then
        echo -e "${RED}❌ $errors missing/invalid variable references${NC}"
        log "ERROR" "Missing variables: ${missing_vars[*]}"
        
        # Alert via Telegram
        local alert_msg="⚠️ Secrets Manager Alert: $errors missing variables in .env: ${missing_vars[*]}"
        echo "$alert_msg"
        
        # Try to send Telegram alert
        if [ -n "$TELEGRAM_BOT_TOKEN" ]; then
            curl -s -X POST "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/sendMessage" \
                -d "chat_id=1083701579" \
                -d "text=$alert_msg" 2>/dev/null || echo "Telegram alert failed"
        fi
        
        return 1
    else
        echo -e "${GREEN}✅ All \${VAR} references verified against .env${NC}"
        log "INFO" "All variable references verified"
        return 0
    fi
}

# Execute the requested action
case $ACTION in
    check)
        do_check
        ;;
    backup)
        do_backup
        ;;
    verify_refs)
        do_verify_refs
        ;;
esac

exit $?